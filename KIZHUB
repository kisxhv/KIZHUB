-- Draggable (mobile touch support)
local dragging, dragInput, dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        local delta = dragInput.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Minimize / Expand Logic
local function toggleMinimize()
    HubMinimized = not HubMinimized
    if HubMinimized then
        MainFrame.Size = UDim2.new(0, 380, 0, 50)  -- Only title bar
        AimToggle.Visible = false
        EspToggle.Visible = false
        MinimizeBtn.Text = "+"
    else
        MainFrame.Size = UDim2.new(0, 380, 0, 280)
        AimToggle.Visible = true
        EspToggle.Visible = true
        MinimizeBtn.Text = "-"
    end
end

MinimizeBtn.MouseButton1Click:Connect(toggleMinimize)

-- Toggle functions
local function updateButton(btn, enabled, text)
    if enabled then
        btn.Text = text .. ": ON"
        btn.BackgroundColor3 = Color3.fromRGB(60, 0, 0)
    else
        btn.Text = text .. ": OFF"
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    end
end

AimToggle.MouseButton1Click:Connect(function()
    AimBotEnabled = not AimBotEnabled
    updateButton(AimToggle, AimBotEnabled, "AIMBOT")
end)

EspToggle.MouseButton1Click:Connect(function()
    ESPEnabled = not ESPEnabled
    updateButton(EspToggle, ESPEnabled, "ESP")
end)

